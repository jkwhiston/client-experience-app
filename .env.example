# Copy this file to .env.local and fill in real values. Never commit .env.local.
# Next.js loads .env.local automatically for local development.

# --- Required (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Required (app login) ---
# If unset, the dev server may fall back to a built-in default — set explicitly for real use.
APP_PASSWORD=change-me

# --- Optional ---
# Firm timezone for deadline math (IANA name). Default in code: America/New_York
# NEXT_PUBLIC_FIRM_TIMEZONE=America/New_York

# PostgreSQL URL for /api/migrate (or pass databaseUrl in the request body)
# DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# If set, Zapier must send this value in x-webhook-secret for /api/webhooks/zapier/client-signed
# ZAPIER_WEBHOOK_SECRET=

# --- Migration CLI only (scripts/apply-migration.mjs), not used by Next.js ---
# DB_PASSWORD=your-database-password
