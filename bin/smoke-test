#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

if [[ ! -d node_modules ]]; then
  echo "error: node_modules missing — run bin/bootstrap-mac or npm ci first" >&2
  exit 1
fi

echo "Running ESLint..."
npm run lint

echo "Running production build..."
npm run build

echo "smoke-test: OK"
